[Unit]
Description=Khadas Camera Server
After=network-online.target avahi-daemon.service
Wants=network-online.target

[Service]
# Run as root (camera + v4l2 + hostname + mDNS)
User=root # System user (not tied to login session)
Group=root

# Type=simple                # Main process, systemd manages it                 
# KillMode=mixed             # Only kill main process on stop
# RemainAfterExit=no         # Don't keep service "active" after process exits
# DefaultDependencies=yes    # Use standard systemd dependencies

# Project directory
#WorkingDirectory=/home/khadas/CAMERA_PROJECT
WorkingDirectory=/home/khadas/PTZ_BENQ_CAMERA
# Environment
Environment=NODE_ENV=production
Environment=PORT=3000

# 👉 IMPORTANT: correct Node binary
#ExecStart=/usr/local/bin/node /home/khadas/CAMERA_PROJECT/server.js
ExecStart=/usr/local/bin/node /home/khadas/PTZ_BENQ_CAMERA/server.js
# Restart policy
Restart=always
RestartSec=3

# Graceful shutdown
KillSignal=SIGINT
TimeoutStopSec=20

# Logging
StandardOutput=journal
StandardError=journal

# System limits (important for ffmpeg + ws)

TasksMax=infinity
LimitNOFILE=65535
Nice=-5 


# Wait for network to really be ready
ExecStartPre=/bin/sleep 5

# Auto restart if system resumes from suspend
RestartForceExitStatus=SIGPIPE

# Security (optional but good)
NoNewPrivileges=true
[Install]
WantedBy=multi-user.target

systemctl is-enabled camera-server.service
systemctl is-active camera-server.service
#cat /etc/systemd/system/camera-server.service  //Reload systemd after editing
sudo nano /etc/systemd/system/camera-server.service 
sudo systemctl daemon-reload
